# ── Banco ───────────────────────────────────────────────────────────
DATABASE_URL=postgres://influa:influa@localhost:5433/influa

# ── Auth / assinaturas ──────────────────────────────────────────────
AUTH_SECRET=            # openssl rand -hex 32
FILE_URL_SECRET=        # openssl rand -hex 32 (assinatura HMAC das URLs de arquivos)

# ── URL pública (Atlas precisa buscar áudio/refs por HTTP) ──────────
# Dev: rode `pnpm tunnel` (cloudflared) e cole a URL https://... aqui.
# Sem túnel, o pipeline usa fallback tmpfiles.org para o áudio.
PUBLIC_BASE_URL=http://localhost:3000

# ── Provedores ──────────────────────────────────────────────────────
ATLAS_API_KEY=
ELEVENLABS_API_KEY=
ANTHROPIC_API_KEY=

# ── Produto ─────────────────────────────────────────────────────────
CREDIT_MARKUP=1.0       # 1 crédito = $0.01 estimado × markup
MODERATION_MODEL=claude-opus-4-8
STORAGE_DIR=./data/storage
