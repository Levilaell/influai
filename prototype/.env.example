# ── Provedor de modelos ─────────────────────────────────────────────
# "fal" ou "atlas". Se omitido: usa atlas quando só ATLAS_API_KEY existir.
PROVIDER=atlas

# ── Atlas Cloud (https://www.atlascloud.ai) ─────────────────────────
ATLAS_API_KEY=
# IDs de modelo da SUA conta — rode `node discover-atlas.js` para listar.
# Defaults: nano-banana-2 / veo-3.1-fast / elevenlabs-v3 / deepseek-v4
#ATLAS_IMAGE_MODEL=
#ATLAS_VIDEO_MODEL=
#ATLAS_TTS_MODEL=
#ATLAS_LLM_MODEL=

# ── fal.ai (https://fal.ai/dashboard/keys) ──────────────────────────
FAL_KEY=

# ── Anthropic (roteiro; opcional se PROVIDER=atlas) ─────────────────
# Se você usa `ant auth login`, pode deixar vazio que o SDK resolve sozinho.
ANTHROPIC_API_KEY=
